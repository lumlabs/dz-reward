# DZ-Reward Configuration
# Copy this file to .env and fill in your values

# Validator identity address (optional - auto-detected from doublezero CLI if not set)
DZ_VALIDATOR_ADDRESS=

# Path to Solana keypair file
DZ_KEYPAIR_PATH=/root/solana/mainnet-validator-keypair.json

# Network (mainnet-beta, testnet, devnet)
DZ_NETWORK=mainnet-beta

# Telegram notifications (optional)
# Create a bot via @BotFather and get your chat ID from @userinfobot
DZ_TELEGRAM_BOT_TOKEN=
DZ_TELEGRAM_CHAT_ID=

# Discord notifications (optional)
# Create a webhook in your Discord server settings
DZ_DISCORD_WEBHOOK_URL=

# Slack notifications (optional)
# Create an incoming webhook in your Slack workspace
DZ_SLACK_WEBHOOK_URL=

# Auto-fund mode (set to 'true' for non-interactive cron jobs)
DZ_AUTO_FUND=false

# Retry configuration
DZ_RETRY_ATTEMPTS=3
DZ_RETRY_DELAY=5

# Payment history log path
DZ_LOG_PATH=~/.dz-reward/payment_history.json
